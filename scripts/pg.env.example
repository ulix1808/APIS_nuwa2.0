# Copia este archivo a pg.env y rellena con tu RDS / Postgres.
#   cp scripts/pg.env.example scripts/pg.env
#
# NO pongas la contraseña aquí (pg.env está en .gitignore).
# En la terminal, antes de migrar:
#   export PGPASSWORD='tu_password'
#
# Mismos campos que el JSON del secreto nuwa2/<env>/database (sin password).

export PGHOST=your-instance.us-east-1.rds.amazonaws.com
export PGPORT=5432
export PGDATABASE=nuwa2
export PGUSER=postgres

# Descomenta si el servidor exige TLS (habitual en RDS público / algunos hosts):
# export PGSSLMODE=require
