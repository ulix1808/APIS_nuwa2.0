# Copia a .env y ajusta. No commitees .env (contiene datos sensibles si añades password).
# Las Lambdas en AWS usan Secrets Manager (nuwa2/<env>/database), no este archivo.

PGHOST=your-instance.us-east-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=nuwa2
PGUSER=postgres
PGSSLMODE=require

# Contraseña solo en shell: export PGPASSWORD='...'
